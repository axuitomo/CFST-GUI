{
  "name": "cfst-gui-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\" \"*.{ts,json}\"",
    "lint": "eslint \"src/**/*.{ts,vue}\" \"*.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" \"*.ts\" --fix",
    "postinstall": "bash ../scripts/patch-android-gradle-warnings.sh",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@dagrejs/dagre": "^3.0.0",
    "@phosphor-icons/vue": "^2.2.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.16",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.4"
  }
}
